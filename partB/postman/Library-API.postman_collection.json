    {
      "name": "16 — 5-аас дээш ном зээлэх оролдлого — 422",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// 5 зээл хийхийн тулд b2, b3, b4, b5, b6 номнуудыг зээлнэ",
              "const books = ['b2','b3','b4','b5','b6'];",
              "const token = pm.environment.get('memberToken');",
              "const baseUrl = pm.environment.get('baseUrl');",
              "",
              "const requests = books.map(bookId => ({",
              "  url: baseUrl + '/loans',",
              "  method: 'POST',",
              "  header: [",
              "    { key: 'Content-Type', value: 'application/json' },",
              "    { key: 'Authorization', value: 'Bearer ' + token }",
              "  ],",
              "  body: { mode: 'raw', raw: JSON.stringify({ bookId: bookId }) }",
              "}));",
              "",
              "// Execute all pre-loans sequentially",
              "function borrowBook(index) {",
              "  if (index >= requests.length) return;",
              "  pm.sendRequest(requests[index], function (err, res) {",
              "    borrowBook(index + 1);",
              "  });",
              "}",
              "borrowBook(0);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 422 — Loan limit exceeded', function () {",
              "  pm.response.to.have.status(422);",
              "});",
              "pm.test('RFC 7807 — loan-limit-exceeded detail', function () {",
              "  pm.response.to.have.header('Content-Type', 'application/problem+json');",
              "  const p = pm.response.json();",
              "  pm.expect(p.status).to.eql(422);",
              "  pm.expect(p.maxLoans).to.eql(5);",
              "  pm.expect(p.activeLoans).to.be.at.least(5);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{memberToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"bookId\": \"b1\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/loans", "host": ["{{baseUrl}}"], "path": ["loans"] }
      }
