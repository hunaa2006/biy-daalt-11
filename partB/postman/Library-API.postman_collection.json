{
	"info": {
		"name": "Library-API-Final",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Login (Auth)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status code is 200', () => pm.response.to.have.status(200));",
							"const json = pm.response.json();",
							"pm.environment.set('token', json.accessToken);",
							"pm.test('Token is received', () => pm.expect(json.accessToken).to.be.a('string'));"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [{"key": "Content-Type", "value": "application/json"}],
				"body": {
					"mode": "raw",
					"raw": "{\"username\":\"admin\", \"password\":\"admin123\"}"
				},
				"url": "{{baseUrl}}/auth/login"
			}
		},
		{
			"name": "2. Create Book",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Book created 201', () => pm.response.to.have.status(201));",
							"const json = pm.response.json();",
							"pm.collectionVariables.set('lastBookId', json.id);",
							"pm.test('Has ID and Title', () => {",
							"  pm.expect(json).to.have.property('id');",
							"  pm.expect(json.title).to.eql('Clean Code');",
							"});"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [{"key": "Content-Type", "value": "application/json"}],
				"body": {
					"mode": "raw",
					"raw": "{\"title\":\"Clean Code\", \"author\":\"Robert Martin\"}"
				},
				"url": "{{baseUrl}}/books"
			}
		},
		{
			"name": "3. Get Books (Pagination/Filter)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status 200', () => pm.response.to.have.status(200));",
							"const json = pm.response.json();",
							"pm.test('Pagination check', () => {",
							"  pm.expect(json.items).to.be.an('array');",
							"  pm.expect(json).to.have.property('total');",
							"});"
						]
					}
				}
			],
			"request": {
				"method": "GET",
				"url": {
					"raw": "{{baseUrl}}/books?page=1&limit=5&title=Clean",
					"host": ["{{baseUrl}}"],
					"path": ["books"],
					"query": [
						{"key": "page", "value": "1"},
						{"key": "limit", "value": "5"},
						{"key": "title", "value": "Clean"}
					]
				}
			}
		},
		{
			"name": "4. Borrow Book (Chained)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Loan created 201', () => pm.response.to.have.status(201));",
							"const json = pm.response.json();",
							"pm.collectionVariables.set('lastLoanId', json.id);",
							"pm.test('Due date set', () => pm.expect(json).to.have.property('dueDate'));"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{"key": "Content-Type", "value": "application/json"},
					{"key": "Authorization", "value": "Bearer {{token}}"}
				],
				"body": {
					"mode": "raw",
					"raw": "{\"memberId\": 2, \"bookId\": {{lastBookId}} }"
				},
				"url": "{{baseUrl}}/loans"
			}
		},
		{
			"name": "5. Error: Borrow same book (422)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status 422 - Unavailable', () => pm.response.to.have.status(422));",
							"pm.test('Problem details format', () => {",
							"  const json = pm.response.json();",
							"  pm.expect(json).to.have.property('status', 422);",
							"  pm.expect(json).to.have.property('title');",
							"});"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{"key": "Content-Type", "value": "application/json"},
					{"key": "Authorization", "value": "Bearer {{token}}"}
				],
				"body": {
					"mode": "raw",
					"raw": "{\"memberId\": 1, \"bookId\": {{lastBookId}} }"
				},
				"url": "{{baseUrl}}/loans"
			}
		},
		{
			"name": "6. Return Book",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Returned 204', () => pm.response.to.have.status(204));"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
				"url": "{{baseUrl}}/loans/{{lastLoanId}}/return"
			}
		},
		{
			"name": "7. Error: 404 Not Found",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status 404', () => pm.response.to.have.status(404));",
							"pm.test('Content-Type is problem+json', () => {",
							"  pm.response.to.have.header('Content-Type', 'application/problem+json; charset=utf-8');",
							"});"
						]
					}
				}
			],
			"request": {
				"method": "GET",
				"url": "{{baseUrl}}/books/9999"
			}
		},
		{
			"name": "8. Error: Unauthorized (401)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status 401', () => pm.response.to.have.status(401));"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"url": "{{baseUrl}}/loans"
			}
		}
	]
}